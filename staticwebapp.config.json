{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/data/*", "/*.{css,js,svg,png,jpg,ico,json}"]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "globalHeaders": {
    "Cache-Control": "no-cache"
  },
  "routes": [
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    }
  ]
}
